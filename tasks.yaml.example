# yaml-language-server: $schema=schemas/task.schema.json
#
# NightCrew Task Queue — termiflow CLI
# Generated from termiflow/TODOS.md Phase 1

tasks:
  - id: admin-endpoints-tests
    title: "Add tests for admin API endpoints"
    branch: test/admin-endpoints
    type: test
    complexity: low
    prompt: |
      Add unit tests for the admin API endpoints in internal/api/admin.go.

      Cover these handlers:
      - handleAdminStats (GET /admin/stats): test 200 response with expected JSON shape,
        test method-not-allowed for non-GET requests.
      - handleIssueKey (POST /admin/keys): test successful key issuance,
        test missing/invalid request body, test method-not-allowed for non-POST requests.
      - handleRevokeKey, handleListKeys, and any other admin handlers in the file.

      Follow the existing test patterns in the codebase (see auth_test.go, keys_test.go
      for how the test Server is set up with a temp SQLite DB).
      Each test should use httptest.NewRequest + httptest.NewRecorder.
      Keep tests focused — one behavior per test function.
    goal: |
      - admin_test.go created with tests for all handlers in admin.go
      - Tests cover success paths, error paths, and method guards
      - All tests pass with `go test ./internal/api/...`
    files_in_scope:
      - internal/api/**
    max_time_minutes: 30
    test_command: "go test ./internal/api/..."

  - id: user-store-tests
    title: "Add tests for UserStore CRUD operations"
    branch: test/user-store
    type: test
    complexity: low
    prompt: |
      Add unit tests for the UserStore in internal/api/user_store.go.

      Cover the core data layer operations:
      - Table creation / schema migration (verify tables exist after init)
      - Subscription CRUD: create, read, update, delete user subscriptions
      - Feed items: insert feed items, query by key/topic, pagination if present
      - Edge cases: duplicate primary key handling, empty results, invalid foreign keys

      Use a fresh in-memory SQLite DB (`sql.Open("sqlite3", ":memory:")`) for each test
      so tests are isolated and fast. Follow the patterns in existing test files.
      No mocking — test against real SQLite.
    goal: |
      - user_store_test.go created with tests for all exported UserStore methods
      - Tests cover happy paths, edge cases, and error conditions
      - All tests pass with `go test ./internal/api/...`
    files_in_scope:
      - internal/api/**
    max_time_minutes: 30
    test_command: "go test ./internal/api/..."

