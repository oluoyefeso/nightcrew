# NightCrew Configuration
# See: https://github.com/nightcrew/nightcrew

# Path to the target repository (absolute or relative)
repo_path: .

# Cost cap per session in cents ($5 default)
max_cost_cents: 500

# Absolute ceiling per task in minutes
max_task_time_minutes: 45

# Models
models:
  default: claude-sonnet-4-20250514     # For low/medium complexity tasks
  complex: claude-opus-4-20250514       # For high complexity tasks

# Branches that NightCrew will never checkout or push to
protected_branches:
  - main
  - master
  - develop
  - production

# Pull request defaults
pr_defaults:
  draft: true
  base: main

# Notifications on run completion
notifications:
  macos: true            # macOS native notification (skipped in headless/SSH)
  webhook_url: ""        # POST JSON payload on completion (Slack, Discord, etc.)
                         # Use env vars for sensitive webhook URLs, not this file
